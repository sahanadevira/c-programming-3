#include<stdio.h>
int main()
{
    int totalrowno, row, space, symbol;
    printf("enter number of rows\n");
    scanf("%d", &totalrowno);
    for(row = 1; row <= totalrowno; row++)
    {
        for(space = 1; space <= (totalrowno - row); space++)
        {
            printf(" ");
        }
        for(symbol = 1; symbol <= (2*row - 1); symbol++)
        {
            printf("*");
        }
        printf("\n");
    }
    return 0;
}
